# Modelo de configuração. Copie para .streamlit/secrets.toml e preencha.
# O arquivo real (secrets.toml) está no .gitignore e NÃO deve ser versionado.
[postgres]
host = "bigdata.dataiesb.com"
port = 5432
user = "SEU_USUARIO"
password = "SUA_SENHA"
dbname = "iesb"

# Credenciais AWS para o chatbot (Amazon Bedrock).
# ATENÇÃO: credenciais com prefixo ASIA... são TEMPORÁRIAS (expiram em ~8h) e
# exigem aws_session_token. Quando expirarem, atualize estes valores.
[aws]
region = "us-east-1"
aws_access_key_id = "SUA_ACCESS_KEY_ID"
aws_secret_access_key = "SUA_SECRET_ACCESS_KEY"
aws_session_token = "SEU_SESSION_TOKEN"
